{
	"name": "transcriber",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite --host",
		"build": "tsc -b && vite build",
		"buildNoCheck": "vite build",
		"lint": "biome check --write",
		"preview": "npm run build && vite preview",
		"deploy": "npm run build && wrangler deploy",
		"deployNoCheck": "npm run buildNoCheck && wrangler deploy",
		"cf-typegen": "wrangler types",
		"db:migration:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply htr_database --local",
		"db:migration:prod": "wrangler d1 migrations apply htr_database --remote",
		"db:viewer": "drizzle-kit studio --port=3001"
	},
	"dependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.0",
		"@mistralai/mistralai": "^1.5.2",
		"@mui/icons-material": "^6.4.4",
		"@mui/material": "^6.4.4",
		"@tailwindcss/vite": "^4.0.6",
		"@tanstack/react-query": "^4.36.1",
		"drizzle-kit": "^0.30.5",
		"drizzle-orm": "^0.40.1",
		"hono": "^4.7.4",
		"i18next": "^25.0.0",
		"i18next-browser-languagedetector": "^8.0.4",
		"i18next-http-backend": "^3.0.2",
		"lodash": "^4.17.21",
		"openai": "^4.85.1",
		"pdfjs-dist": "^5.1.91",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-dropzone": "^14.3.5",
		"react-i18next": "^15.4.1",
		"react-responsive": "^10.0.0",
		"react-router-dom": "^7.1.5",
		"react-toastify": "^11.0.5",
		"react-zoom-pan-pinch": "^3.7.0",
		"tailwindcss": "^4.0.6",
		"valibot": "^1.0.0-rc.4",
		"zustand": "^5.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@cloudflare/vite-plugin": "^1.0.10",
		"@libsql/client": "^0.15.4",
		"@types/lodash": "^4.17.16",
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.5",
		"@vitejs/plugin-react": "^4.4.1",
		"dotenv": "^16.5.0",
		"fast-glob": "^3.3.3",
		"globals": "^15.14.0",
		"lefthook": "^1.11.3",
		"typescript": "^5.8.2",
		"vite": "^6.3.2",
		"vite-tsconfig-paths": "^5.1.4",
		"wrangler": "^4.13.0"
	}
}
