{
    "name": "transcriber",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "build": "tsc -b && vite build",
        "buildNoCheck": "vite build",
        "lint": "biome check --write",
        "preview": "npm run build && vite preview",
        "deploy": "npm run build && wrangler deploy",
        "deployNoCheck": "npm run buildNoCheck && wrangler deploy",
        "cf-typegen": "wrangler types",
        "db:migration:generate": "drizzle-kit generate",
        "db:migrate:local": "wrangler d1 migrations apply htr_database --local",
        "db:migration:prod": "wrangler d1 migrations apply htr_database --remote",
        "db:viewer": "drizzle-kit studio --port=3001"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.0",
        "@mistralai/mistralai": "^1.6.0",
        "@mui/icons-material": "^7.0.2",
        "@mui/material": "^7.0.2",
        "@tailwindcss/vite": "^4.1.4",
        "@tanstack/react-query": "^5.74.4",
        "drizzle-kit": "^0.31.0",
        "drizzle-orm": "^0.43.1",
        "hono": "^4.7.7",
        "i18next": "^25.0.1",
        "i18next-browser-languagedetector": "^8.0.5",
        "i18next-http-backend": "^3.0.2",
        "lodash": "^4.17.21",
        "logrocket": "^10.1.0",
        "openai": "^4.96.0",
        "pdfjs-dist": "^5.1.91",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-dropzone": "^14.3.8",
        "react-i18next": "^15.5.1",
        "react-resizable-panels": "^3.0.2",
        "react-responsive": "^10.0.1",
        "react-router-dom": "^7.5.2",
        "react-toastify": "^11.0.5",
        "react-zoom-pan-pinch": "^3.7.0",
        "tailwindcss": "^4.1.4",
        "valibot": "^1.0.0",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@biomejs/biome": "1.9.4",
        "@cloudflare/vite-plugin": "^1.0.12",
        "@libsql/client": "^0.15.4",
        "@types/lodash": "^4.17.16",
        "@types/react": "^19.1.2",
        "@types/react-dom": "^19.1.2",
        "@vitejs/plugin-react": "^4.4.1",
        "dotenv": "^16.5.0",
        "fast-glob": "^3.3.3",
        "globals": "^16.0.0",
        "lefthook": "^1.11.11",
        "typescript": "^5.8.3",
        "vite": "^6.3.3",
        "vite-tsconfig-paths": "^5.1.4",
        "wrangler": "^4.13.2"
    }
}
